datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider             = "prisma-client-py"
  interface            = "sync"
  recursive_type_depth = 5
}

model Post {
  id          String     @id @default(cuid())
  title       String
  content     String?
  published   Boolean
  description String?
}

